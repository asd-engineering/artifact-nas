# Copy this file to .env and fill in your values. .env is git-ignored.
# These drive the justfile recipes (local rclone config + pushing GitHub secrets).

# --- NAS SFTP endpoint ---
NAS_HOST=nas.example.com
NAS_USER=ci-user
NAS_PORT=22

# --- rclone remote name + destination path on the NAS ---
# NOTE: many NAS SFTP accounts are chrooted to their shares, so put the dest
# under an existing share (e.g. /Home/ci-artifacts), not a bare /artifacts.
NAS_REMOTE=artifacts-nas
NAS_DEST=/Home/ci-artifacts

# --- GitHub org the secrets are pushed to (gh secret set --org ...) ---
GH_ORG=your-org

# --- Local rclone config file the recipes read/write ---
RCLONE_CONFIG_FILE=.rclone/rclone.conf
